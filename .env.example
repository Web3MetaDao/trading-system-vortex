# ============================================================
# VORTEX Trading System - Environment Configuration Template
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# ============================================================

# --- Binance API ---
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here
# Set to "true" for Binance Testnet
BINANCE_TESTNET=false

# --- Telegram Notifications ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# --- System Mode ---
# Options: paper | live
EXECUTION_MODE=paper

# --- Cross-Exchange Arbitrage (Optional) ---
OKX_API_KEY=
OKX_API_SECRET=
OKX_PASSPHRASE=
BYBIT_API_KEY=
BYBIT_API_SECRET=

# --- Multimodal Oracle (Optional) ---
# Used for macro sentiment filtering
OPENAI_API_KEY=
FEAR_GREED_API_URL=https://api.alternative.me/fng/

# --- Logging ---
LOG_LEVEL=INFO
LOG_FILE=logs/vortex.log
